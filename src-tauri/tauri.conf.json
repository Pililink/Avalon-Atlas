{
    "productName": "avalon-atlas",
    "version": "2.0.0",
    "identifier": "com.avalon-atlas.desktop",
    "build": {
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build",
        "devUrl": "http://localhost:1420",
        "frontendDist": "../build/frontend"
    },
    "app": {
        "windows": [
            {
                "title": "Avalon Atlas",
                "width": 390,
                "height": 840,
                "resizable": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "resources": {
            "../public/static/data/maps.json": "static/data/maps.json",
            "binaries/tesseract/": "binaries/tesseract/",
            "binaries/tessdata/": "binaries/tessdata/"
        },
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/icon.ico",
            "icons/icon.icns"
        ]
    }
}
